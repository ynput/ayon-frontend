{
  "name": "ayon-frontend",
  "private": false,
  "version": "0.3.1",
  "scripts": {
    "dev": "vite --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "eslint --fix 'src/**/*.{jsx,ts,tsx}'",
    "format": "prettier --write src/**/*.{js,jsx} --config ./.prettierrc",
    "upgrade-arc": "yarn upgrade @ynput/ayon-react-components@latest",
    "generate-token": "node --env-file=.env.local ./gen/getAuth.js",
    "download-openapi": "node ./gen/download-schema.js",
    "generate-rest-all": "yarn download-openapi && npx @rtk-query/codegen-openapi ./gen/openapi-config.ts && node ./gen/process-api-types.js",
    "generate-rest": " npx @rtk-query/codegen-openapi ./gen/openapi-config.ts",
    "generate-gql": "cd gen && graphql-codegen --require dotenv/config",
    "test": "npx playwright test",
    "test-ui": "npx playwright test --ui",
    "test-auth": "npx playwright test auth.setup.js",
    "test-report": "yarn playwright show-report",
    "test-codegen": "npx playwright codegen http://localhost:3000 --load-storage=playwright/.auth/user.json",
    "dev-arc": "yarn setup:arc && concurrently \"yarn watch:arc\" \"vite --port 3000 --force\"",
    "setup:arc": "cd ../ayon-react-components && yarn link && cd - && yarn link @ynput/ayon-react-components",
    "watch:arc": "nodemon --watch ../ayon-react-components/dist --exec \"yarn link @ynput/ayon-react-components\"",
    "arc-unlink": "yarn unlink @ynput/ayon-react-components && yarn install --force"
  },
  "dependencies": {
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "8.0.0",
    "@reduxjs/toolkit": "2.11.2",
    "@rjsf/core": "5.22.1",
    "@rjsf/utils": "5.22.1",
    "@rjsf/validator-ajv8": "5.22.1",
    "@rtk-query/codegen-openapi": "2.2.0",
    "@rtk-query/graphql-request-base-query": "2.3.2",
    "@tanstack/match-sorter-utils": "8.19.4",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.23",
    "@uiw/react-textarea-code-editor": "2.1.9",
    "@ynput/ayon-react-components": "^1.17.2",
    "axios": "1.15.0",
    "chart.js": "4.5.1",
    "clsx": "2.1.1",
    "custom-protocol-check": "1.4.0",
    "date-fns": "3.6.0",
    "dotenv": "16.6.1",
    "fscreen": "1.2.0",
    "graphql": "16.13.2",
    "graphql-request": "7.4.0",
    "html-to-image": "1.11.13",
    "lodash": "4.18.1",
    "match-sorter": "6.4.0",
    "object-scan": "19.0.5",
    "papaparse": "^5.5.3",
    "primeicons": "7.0.0",
    "primereact": "9.6.2",
    "primereact-context": "npm:primereact@9.2.3",
    "quill-magic-url": "^4.2.0",
    "react": "18.3.1",
    "react-datepicker": "4.25.0",
    "react-dom": "18.3.1",
    "react-error-boundary": "4.1.2",
    "react-full-screen": "1.1.1",
    "react-helmet": "6.1.0",
    "react-intersection-observer": "9.16.0",
    "react-markdown": "10.1.0",
    "react-perfect-scrollbar": "1.5.8",
    "react-quill-ayon": "2.0.2",
    "react-redux": "9.2.0",
    "react-router": "6.30.3",
    "react-router-dom": "6.30.3",
    "react-toastify": "9.1.3",
    "react-transition-group": "4.4.5",
    "react-use-websocket": "4.13.0",
    "rehype-external-links": "3.0.0",
    "rehype-raw": "7.0.0",
    "remark-directive": "3.0.1",
    "remark-directive-rehype": "0.4.2",
    "remark-emoji": "4.0.1",
    "remark-gfm": "4.0.1",
    "remove-markdown": "0.6.3",
    "sass": "1.99.0",
    "searchhash": "1.2.13",
    "semver": "7.7.4",
    "short-uuid": "4.2.2",
    "styled-components": "6.4.0",
    "turndown": "7.2.4",
    "use-query-params": "2.2.2",
    "uuid": "9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@graphql-codegen/add": "6.0.1",
    "@graphql-codegen/cli": "6.3.0",
    "@graphql-codegen/introspection": "5.0.2",
    "@graphql-codegen/near-operation-file-preset": "5.0.0",
    "@graphql-codegen/typed-document-node": "6.1.8",
    "@graphql-codegen/typescript": "5.0.10",
    "@graphql-codegen/typescript-operations": "5.1.0",
    "@graphql-codegen/typescript-rtk-query": "4.0.0",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@module-federation/enhanced": "2.3.2",
    "@module-federation/vite": "1.14.2",
    "@playwright/test": "1.59.1",
    "@types/lodash": "4.17.24",
    "@types/node": "20.19.39",
    "@types/papaparse": "^5.5.2",
    "@types/react": "18.3.28",
    "@types/react-dom": "18.3.7",
    "@types/semver": "7.7.1",
    "@types/styled-components": "5.1.36",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitejs/plugin-react": "4.7.0",
    "babel-plugin-styled-components": "2.1.4",
    "concurrently": "9.2.1",
    "dotenv": "16.6.1",
    "esbuild-runner": "2.2.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "globals": "16.5.0",
    "prettier": "2.8.8",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vite": "7.3.2",
    "vite-plugin-linter": "3.1.1"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "yarn eslint",
      "yarn format"
    ]
  },
  "graphql": {
    "schema": "./gen/graphql.schema.json",
    "documents": "**/*.graphql"
  }
}
